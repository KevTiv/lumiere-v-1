# Server
PORT=8080

# Qdrant (self-hosted or Qdrant Cloud)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=           # leave empty for local, set for Qdrant Cloud
QDRANT_COLLECTION=lumiere_embeddings

# Voyage AI (https://www.voyageai.com)
VOYAGE_API_KEY=your-voyage-api-key-here

# Anthropic Claude (https://console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Embedding model config
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# SpacetimeDB connection (for reducer callbacks and queue polling)
STDB_HOST=http://localhost:3000
STDB_MODULE=lumiere-v1
STDB_TOKEN=your-stdb-token-here   # from: spacetime login --token

# Queue worker
WORKER_POLL_SECS=10      # how often to poll for pending embedding jobs
WORKER_BATCH_SIZE=20     # max jobs per poll cycle
