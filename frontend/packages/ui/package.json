{
  "name": "@lumiere/ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "add": "pnpm dlx shadcn@latest add",
    "add:native": "pnpm dlx @react-native-reusables/cli@latest add"
  },
  "dependencies": {
    "@lumiere/i18n": "workspace:*",
    "@base-ui/react": "^1.2.0",
    "@codemirror/commands": "^6.0.0",
    "@codemirror/lang-python": "^6.0.0",
    "@codemirror/state": "^6.0.0",
    "@codemirror/theme-one-dark": "^6.0.0",
    "@codemirror/view": "^6.0.0",
    "@uiw/react-codemirror": "^4.23.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-toast": "1.2.15",
    "@radix-ui/react-tooltip": "1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.577.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-resizable-panels": "^4.7.2",
    "recharts": "2.15.4",
    "shadcn": "^4.0.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "^3.25.76",
    "i18next": "^25.8.17",
    "leaflet": "^1.9.4",
    "react-leaflet": "^4.2.1"
  },
  "peerDependencies": {
    "react-native": ">=0.76.0",
    "react-native-reanimated": ">=3.0.0",
    "react-native-svg": ">=15.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@turbo/gen": "^2.8.1",
    "@types/node": "^25.1.0",
    "@types/leaflet": "^1.9.14",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.2",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./native": {
      "types": "./src/native/index.ts",
      "default": "./src/native/index.ts"
    },
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts",
    "./map-components/*": "./src/map-components/*.tsx",
    "./native/*": "./src/native/**/*.ts",
    "./native/primitives/*": "./src/native/primitives/*.tsx",
    "./native/lib/*": "./src/native/lib/*.ts"
  }
}
