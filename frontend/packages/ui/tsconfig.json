{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@lumiere/ui/*": ["./src/*"],
      "@/components/ui/*": ["./src/components/*"],
      "@/components/*": ["./src/*"],
      "@/lib/*": ["./src/lib/*"],
      "@/hooks/*": ["./src/hooks/*"]
    },
    "jsx": "react-jsx",
    "typeRoots": ["./node_modules/@types", "../mobile/node_modules/@types"]
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"],
  "references": [
    { "path": "../mobile" }
  ]
}
