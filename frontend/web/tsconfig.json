{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES2020",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/components/ui/*": [
        "../packages/ui/src/components/*"
      ],
      "@/components/*": [
        "../packages/ui/src/*"
      ],
      "@/lib/*": [
        "./lib/*",
        "../packages/ui/src/lib/*"
      ],
      "@/hooks/*": [
        "./hooks/*",
        "../packages/ui/src/hooks/*"
      ],
      "@lumiere/ui": [
        "../packages/ui/src/index.ts"
      ],
      "@lumiere/ui/*": [
        "../packages/ui/src/*"
      ],
      "@lumiere/stdb": [
        "../packages/stdb/src/index.ts"
      ],
      "@lumiere/stdb/*": [
        "../packages/stdb/src/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
