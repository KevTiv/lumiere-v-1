# IoT Gateway Configuration

# HTTP server port (default: 8081)
PORT=8081

# SpacetimeDB connection
STDB_HOST=http://localhost:3000
STDB_MODULE=lumiere-v1
STDB_TOKEN=your_token_here

# MQTT broker
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_CLIENT_ID=lumiere-iot-gateway
# MQTT_USERNAME=user      # optional
# MQTT_PASSWORD=password  # optional

# Action dispatcher poll interval (seconds, default: 5)
ACTION_POLL_SECS=5

# Default organization ID to use when calling reducers from MQTT messages
DEFAULT_ORG_ID=1
